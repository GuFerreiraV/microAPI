<Window
    x:Class="microAPI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:microAPI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:microAPI.ViewModels"
    xmlns:converters="using:microAPI.Converters"
    Title="Micro API"
    Width="1000"
    Height="600"
    x:CompileBindings="False"
    Icon="{Binding IsOnline, Converter={StaticResource StatusToIconConverter}}"
    WindowState="Normal"
    mc:Ignorable="d">

    <!--
        Grid Principal Separadora (Sidebar e Conteúdo)
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!--  Sidebar  -->
            <ColumnDefinition Width="Auto" />
            <!--  Contéudo Principal  -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ========================SIDEBAR========================  -->
        <Border
            Grid.Column="0"
            Width="260"
            Background="#F9F9F9"
            BorderBrush="#E5E5E5"
            BorderThickness="0,0,1,0"
            IsVisible="{Binding IsSidebarOpen}">
            <Grid RowDefinitions="Auto, *">
                <!--  Botão Nova Coleção  -->
                <Button
                    Grid.Row="0"
                    Margin="12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding AddNewCollectionCommand}"
                    Content="+ Nova Coleção" />
                <!--  Lista de Coleções  -->
                <TextBlock
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="Gray"
                    Text="Nenhuma coleção criada" />
            </Grid>
        </Border>
        <!--  ========================CONTEÚDO PRINCIPAL========================  -->
        <!--  Barra superior: Método HTTP, URL e Botão de Enviar  -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Command="{Binding ToggleSidebarCommand}"
                    Content="☰" />

                <ComboBox
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding HttpMethods}"
                    SelectedItem="{Binding SelectedMethod}">
                    <!--  Template de exibição customizado  -->
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="{Binding, Converter={StaticResource MethodToColorConverter}}"
                                Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox
                    Grid.Column="2"
                    Margin="0,0,8,0"
                    PlaceholderText="URL da Requisição"
                    Text="{Binding Url}" />

                <Button
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding ExecuteRequestCommand}"
                    Content="Enviar"
                    IsEnabled="{Binding !IsLoading}" />
            </Grid>

            <!--  Request Body  -->
            <HeaderedContentControl
                Grid.Row="1"
                Margin="0,0,0,8"
                Header="Request Body (JSON)">
                <TextBox
                    MinHeight="100"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding RequestBody}" />
            </HeaderedContentControl>

            <!--  Status e Indicador de Progresso  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10"
                Orientation="Horizontal">
                <TextBlock FontWeight="Bold" Text="Status: " />
                <TextBlock Foreground="DarkCyan" Text="{Binding StatusCode}" />
                <!--  No Avalonia, IsVisible aceita propriedades booleanas diretamente  -->
                <ProgressBar
                    Width="100"
                    Height="4"
                    Margin="10,0,0,0"
                    IsIndeterminate="True"
                    IsVisible="{Binding IsLoading}" />
            </StackPanel>

            <!--  Response Body  -->
            <HeaderedContentControl Grid.Row="3" Header="Response">
                <TextBox
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding ResponseBody}" />
            </HeaderedContentControl>
        </Grid>
    </Grid>
</Window>
