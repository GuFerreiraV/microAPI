<Window
    x:Class="microAPI.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:microAPI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:microAPI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:microAPI.ViewModels"
    xmlns:i="clr-namespace:Optris.Icons.Avalonia;assembly=Optris.Icons.Avalonia" 
    Title="Micro API"
    Width="1000"
    Height="600"
    x:CompileBindings="False"
    Icon="{Binding IsOnline, Converter={StaticResource StatusToIconConverter}}"
    WindowState="Normal"
    mc:Ignorable="d">

    <!--
        Grid Principal Separadora (Sidebar e Conteúdo)
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!--  Sidebar  -->
            <ColumnDefinition Width="Auto" />
            <!--  Contéudo Principal  -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ========================SIDEBAR========================  -->
        <Border
            Grid.Column="0"
            Width="260"
            Background="#F9F9F9"
            BorderBrush="#E5E5E5"
            BorderThickness="0,0,1,0"
            IsVisible="{Binding IsSidebarOpen}">
            <Grid RowDefinitions="Auto, *">
                <!--  Botão Nova Coleção  -->
                <Button
                    Grid.Row="0"
                    Margin="12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding AddNewCollectionCommand}"
                    Content="+ Nova Coleção" />
                <ScrollViewer Grid.Row="1" Margin="4,0">
                    <ItemsControl ItemsSource="{Binding Collections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <!--  Cabeçalho da coleção  -->
                                    <Grid Margin="8,4" ColumnDefinitions="Auto, *, Auto, Auto">
                                        <!--  Cabeçalho da coleção  -->
                                        <Button
                                            Grid.Column="0"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding ToggleExpandCommand}"
                                            Content="{Binding Arrow}"
                                            FontSize="10" />

                                        <Panel
                                            Grid.Column="1"
                                            Margin="8,0"
                                            VerticalAlignment="Center">
                                            <!--  Modo Leitura (Clique duplo ativa edição)  -->
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                DoubleTapped="TextBlock_DoubleTapped"
                                                FontWeight="SemiBold"
                                                IsVisible="{Binding !IsEditingName}"
                                                Text="{Binding Name}" />
                                            <!--  Modo Escrita  -->
                                            <TextBox
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding IsEditingName}"
                                                KeyDown="TextBox_KeyDown"
                                                LostFocus="TextBox_LostFocus"
                                                PlaceholderText="Nova Coleção"
                                                Text="{Binding Name}" />
                                        </Panel>
                                        <!--  Botão para remover uma coleção  -->
                                        <Button
                                            Grid.Column="2"
                                            Padding="0,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding RemoveCollectionCommand}"
                                            i:Attached.Icon="fa-regular fa-trash-can"                                            
                                             />
                                        <!--  Botão + para adicionar requisição  -->
                                        <Button
                                            Grid.Column="3"
                                            Padding="6,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding AddRequestCommand}"
                                            i:Attached.Icon="fa-solid fa-plus"
                                            />
                                    </Grid>
                                    <!--  2. Lista de Requisições da Coleção (Oculta se !IsExpanded)  -->
                                    <ItemsControl
                                        Margin="20,0,0,0"
                                        IsVisible="{Binding IsExpanded}"
                                        ItemsSource="{Binding Requests}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="8,2" ColumnDefinitions="Auto, Auto, *, Auto">
                                                    <ComboBox
                                                        Grid.Column="0"
                                                        Margin="0,0,4,0"
                                                        Padding="4,2"
                                                        FontSize="10"
                                                        IsVisible="{Binding IsEditingName}"
                                                        ItemsSource="{Binding HttpMethods}"
                                                        SelectedItem="{Binding Method}" />
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="4,1"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                                        CornerRadius="3"
                                                        IsVisible="{Binding !IsEditingName}">
                                                        <TextBlock
                                                            FontSize="9"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="{Binding Method}" />
                                                    </Border>
                                                    <Panel
                                                        Grid.Column="2"
                                                        Margin="8,0"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            DoubleTapped="TextBlock_DoubleTapped"
                                                            FontSize="12"
                                                            IsVisible="{Binding !IsEditingName}"
                                                            Text="{Binding Name}" />

                                                        <TextBox
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            IsVisible="{Binding IsEditingName}"
                                                            KeyDown="TextBox_KeyDown"
                                                            LostFocus="TextBox_LostFocus"
                                                            PlaceholderText="Nova Requisição"
                                                            Text="{Binding Name}" />
                                                    </Panel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        <!--  ========================CONTEÚDO PRINCIPAL========================  -->
        <!--  Barra superior: Método HTTP, URL e Botão de Enviar  -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Command="{Binding ToggleSidebarCommand}"
                    Content="☰" />

                <ComboBox
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding HttpMethods}"
                    SelectedItem="{Binding SelectedMethod}">
                    <!--  Template de exibição customizado  -->
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="{Binding, Converter={StaticResource MethodToColorConverter}}"
                                Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox
                    Grid.Column="2"
                    Margin="0,0,8,0"
                    PlaceholderText="URL da Requisição"
                    Text="{Binding Url}" />

                <Button
                    Grid.Column="3"                    
                    HorizontalAlignment="Stretch"                    
                    HorizontalContentAlignment="Center"
                    Command="{Binding ExecuteRequestCommand}"
                    IsEnabled="{Binding !IsLoading}" 
                    Background="#09bd4e"                                     
                    Foreground="White" 
                    Content="Enviar"
                    />
            </Grid>

            <!--  Request Body  -->
            <HeaderedContentControl
                Grid.Row="1"
                Margin="0,0,0,8"
                Header="Request Body">
                <TextBox
                    MinHeight="100"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding RequestBody}" />
            </HeaderedContentControl>

            <!--  Status e Indicador de Progresso  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10"
                Orientation="Horizontal">
                <TextBlock FontWeight="Bold" Text="Status: " />
                <TextBlock Foreground="DarkCyan" Text="{Binding StatusCode}" />
                <!--  No Avalonia, IsVisible aceita propriedades booleanas diretamente  -->
                <ProgressBar
                    Width="100"
                    Height="4"
                    Margin="10,0,0,0"
                    IsIndeterminate="True"
                    IsVisible="{Binding IsLoading}" />
            </StackPanel>

            <!--  Response Body  -->
            <HeaderedContentControl Grid.Row="3" Header="Response">
                <TextBox
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding ResponseBody}" />
            </HeaderedContentControl>
        </Grid>
    </Grid>
</Window>
